{
  "buildCommand": "pnpm run typecheck && PORT=3000 BASE_PATH=/ pnpm --filter @workspace/asivanta run build",
  "outputDirectory": "artifacts/asivanta/dist/public",
  "framework": null,
  "functions": {
    "api/contact.ts": {
      "memory": 512,
      "maxDuration": 15
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
